Options -MultiViews
RewriteEngine On
RewriteBase /data/

# 1. Hapus index.php dari URL (Redirect ke root folder relatif)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.*?/)?index\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Hapus .php dari URL (Redirect ke versi bersih relatif)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Cek apakah ada file .php yang cocok untuk URL tanpa ekstensi (Internal rewrite)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [NC,L]

# 4. Routing Fallback ke home.php (Untuk datasiswa, arsipdata, dll)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?$1 [L,QSA]
